# LayoutArena API keys
# Copy this file to .env and fill in your keys.

# Google Gemini (AI Studio)
GEMINI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Groq
GROQ_API_KEY=

# Perplexity
PERPLEXITYAI_API_KEY=

# Azure OpenAI (optional)
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# Optional: cap async LLM concurrency (0 = unlimited)
# MPS_LLM_MAX_CONCURRENCY=0
